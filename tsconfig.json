{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["agents/**/*.ts", "scheduler/**/*.ts", "services/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
